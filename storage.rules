rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /profile-photos/{fileName} {
      function ownsProfilePhoto() {
        return request.auth != null && fileName == request.auth.uid + ".jpg";
      }

      allow read: if request.auth != null;
      allow create, update: if ownsProfilePhoto()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if ownsProfilePhoto();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
